# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Email — Gmail SMTP (ส่งหาใครก็ได้ฟรี 500/วัน)
# วิธีหา App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_FROM=AF Dashboard <your-email@gmail.com>

# App
NEXT_PUBLIC_APP_URL=https://af-dashboard.vercel.app

# Cron protection
CRON_SECRET=replace-with-random-secret
